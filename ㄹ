for a in range(1, 21):
    print(a, end=" ")  # 숫자를 먼저 출력 (옆에 표시되게 end 추가)
    
    if a % 12 == 0:
        # 12의 배수일 때
        print("o")
    elif a % 4 == 0:
        # 12의 배수가 아니고 4의 배수일 때
        print("x")
    elif a % 2 == 0:
        # 12의 배수도 4의 배수도 아니면서 2의 배수일 때
        print("#")
    else:
        # 그 외 아무것도 아닐 때
        print("@")
